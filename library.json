{
  "$schema": "https://raw.githubusercontent.com/platformio/platformio-core/develop/platformio/assets/schema/library.json",
  "name": "lsh-bridge",
  "version": "1.4.2",
  "description": "Reusable ESP32 bridge runtime for the LSH ecosystem, connecting serial controllers to MQTT and Homie.",
  "license": "Apache-2.0",
  "keywords": ["lsh", "esp32", "mqtt", "homie", "bridge", "serial", "msgpack"],
  "authors": [
    {
      "name": "Jacopo Labardi",
      "url": "https://github.com/labodj",
      "maintainer": true
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/labodj/lsh-bridge.git"
  },
  "homepage": "https://github.com/labodj/lsh-bridge",
  "frameworks": "arduino",
  "platforms": "espressif32",
  "dependencies": [
    {
      "owner": "bblanchon",
      "name": "ArduinoJson",
      "version": "^6.21.6"
    },
    {
      "owner": "etlcpp",
      "name": "Embedded Template Library",
      "version": "20.47.1"
    },
    {
      "owner": "labodj",
      "name": "homie-v5",
      "version": "3.3.1"
    }
  ],
  "build": {
    "libLDFMode": "deep+"
  },
  "export": {
    "include": [
      "CITATION.cff",
      "LICENSE",
      "NOTICE",
      "README.md",
      "docs/*",
      "examples/basic-homie-bridge/include/*",
      "examples/basic-homie-bridge/platformio.ini",
      "examples/basic-homie-bridge/src/*",
      "include/*",
      "library.json",
      "src/*",
      "src/communication/*",
      "src/constants/*",
      "src/constants/configs/*",
      "src/debug/*",
      "src/utils/*"
    ]
  }
}
